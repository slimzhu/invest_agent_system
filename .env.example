# OpenRouter / OpenAI-compatible endpoint
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# App mode
APP_ENV=dev
DISABLE_TRACING=true

# Model selection
RESEARCH_MODEL=gpt-4.1-mini
VALUE_TRADER_MODEL=gpt-4.1-mini
GROWTH_TRADER_MODEL=gpt-4.1-mini
MACRO_TRADER_MODEL=gpt-4.1-mini
EVENT_TRADER_MODEL=gpt-4.1-mini
VALIDATOR_MODEL=gpt-4.1-mini

# Market / search data sources
FINNHUB_API_KEY=your_finnhub_api_key_here
BRAVE_API_KEY=your_brave_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here

# SEC access
SEC_USER_AGENT=your_name your_project your_email@example.com

# Source toggles
RESEARCH_SOURCE_ENABLE_FINNHUB=true
RESEARCH_SOURCE_ENABLE_BRAVE=true
RESEARCH_SOURCE_ENABLE_POLYGON=false
RESEARCH_SOURCE_ENABLE_SEC=true
RESEARCH_SOURCE_ENABLE_RESEARCH_FEED=false

# Optional proxy
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
